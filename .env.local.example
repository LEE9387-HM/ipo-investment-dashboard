# =============================================================================
# IPO Investment Dashboard - API 키 설정 파일
# =============================================================================
# 이 파일을 복사하여 .env.local 로 저장한 뒤 실제 값을 입력하세요.
#   cp .env.local.example .env.local
#
# ⚠️  .env.local 은 절대 git에 커밋하지 마세요. (.gitignore 에 등록 필수)
# =============================================================================

# -----------------------------------------------------------------------------
# [필수] DART OpenAPI - 기업 공시 데이터 수집
# 발급: https://opendart.fss.or.kr/uss/usr/ehAuthManagg/insertManaggForm.do
# -----------------------------------------------------------------------------
DART_API_KEY=

# -----------------------------------------------------------------------------
# [필수] 한국투자증권(KIS) Open API - 실질 주가 및 시장 데이터 수집
# 발급: https://apiportal.koreainvestment.com/intro
# -----------------------------------------------------------------------------
KIS_APP_KEY=
KIS_APP_SECRET=
# KIS API 환경: real (실전) 또는 virtual (모의투자)
KIS_ENVIRONMENT=real

# -----------------------------------------------------------------------------
# [필수] Google Gemini API - AI 기반 주가 예측 및 데이터 요약
# 발급: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# [필수] Telegram Bot - 실시간 알림 발송
# 발급: https://t.me/BotFather 에서 /newbot 명령으로 생성
# Chat ID: @userinfobot 또는 getUpdates API로 확인
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
